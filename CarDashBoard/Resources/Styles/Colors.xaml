<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

    <!--CarDashboardShowcaseLightTheme-->
    <Color x:Key="CarDashBoardBackgroundLight">#FFFFFF</Color>
    <Color x:Key="CarDashBoardForegroundLight">#7B7B7B</Color>
    <Color x:Key="CarDashBoardIconLight">#C0C0C0</Color>
    <Color x:Key="CarDashBoardNeedleFillLight">#4D4D4D</Color>
    <Color x:Key="CarDashBoardLineStyleLight">#C0C0C0</Color>
    <Color x:Key="CarDashBoardRangeLayer1Light">#80D8E5FF</Color>
    <Color x:Key="CarDashBoardRangeLayer2Light">#66D8E5FF</Color>
    <Color x:Key="CarDashBoardRangeLayer3Light">#4CD8E5FF</Color>
    <Color x:Key="CarDashBoardRangeLayer4Light">#33D8E5FF</Color>
    <Color x:Key="CarDashBoardFuelGaugeLight">#B9B9B9</Color>
    <Color x:Key="CarDashBoardIconGreenLight">#0AB237</Color>
    <Color x:Key="CarDashBoardIconBlueLight">#1B5FCF</Color>
    <Color x:Key="CarDashBoardIconYellowLight">#EBBF0F</Color>
    <Color x:Key="CarDashBoardIconOrangeLight">#F48007</Color>
    <Color x:Key="CarDashBoardIconRedLight">#FF3E2E</Color>
    <Color x:Key="CarDashBoardSpeedometerLayer1Light">#498CFA</Color>
    <Color x:Key="CarDashBoardSpeedometerLayer2Light">#FF2F1E</Color>
    <Color x:Key="CarDashBoardSpeedometerLayer3Light">#A20505</Color>
    <Color x:Key="CarDashBoardDigitalGaugeLight">#C29402</Color>

    <!--CarDashboardShowcaseDarkTheme-->
    <Color x:Key="CarDashBoardBackgroundDark">#000000</Color>
    <Color x:Key="CarDashBoardForegroundDark">#FFFFFF</Color>
    <Color x:Key="CarDashBoardIconDark">#33D3FF</Color>
    <Color x:Key="CarDashBoardNeedleFillDark">#E20000</Color>
    <Color x:Key="CarDashBoardLineStyleDark">#FFFFFF</Color>
    <Color x:Key="CarDashBoardRangeLayer1Dark">#660059FF</Color>
    <Color x:Key="CarDashBoardRangeLayer2Dark">#4D0059FF</Color>
    <Color x:Key="CarDashBoardRangeLayer3Dark">#330059FF</Color>
    <Color x:Key="CarDashBoardRangeLayer4Dark">#1A0059FF</Color>
    <Color x:Key="CarDashBoardFuelGaugeDark">#FFFFFF</Color>
    <Color x:Key="CarDashBoardIconGreenDark">#00E93E</Color>
    <Color x:Key="CarDashBoardIconBlueDark">#4285F4</Color>
    <Color x:Key="CarDashBoardIconYellowDark">#FFBE02</Color>
    <Color x:Key="CarDashBoardIconOrangeDark">#FF9629</Color>
    <Color x:Key="CarDashBoardIconRedDark">#FF3E2E</Color>
    <Color x:Key="CarDashBoardSpeedometerLayer1Dark">#3B79DF</Color>
    <Color x:Key="CarDashBoardSpeedometerLayer2Dark">#FF3E2E</Color>
    <Color x:Key="CarDashBoardSpeedometerLayer3Dark">#E90000</Color>
    <Color x:Key="CarDashBoardDigitalGaugeDark">#FFC300</Color>
    
</ResourceDictionary>